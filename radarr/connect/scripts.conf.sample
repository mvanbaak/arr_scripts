# SAMPLE configuration file
# Move this file to 'scripts.conf' in the same directory
# as the connect/custom/trigger scripts

# Radarr info used to talk to its api
RADARR_API_URL="http://ip.of.radarr:7878/api/v3"
RADARR_API_KEY="your_radarr_api_key"

# TMDB API key for trailer lookups
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY="your_tmdb_api_key"

# Trailer languages to download (comma-separated, ISO 639-1 with optional region)
# "original" is a special value that resolves to the movie's original language at runtime
TRAILER_LANGUAGES="original,pt-BR"

# Subtitle languages to download for original-language trailers (comma-separated)
# Uses yt-dlp's --sub-langs. Empty value disables subtitles.
TRAILER_SUBTITLE_LANGS="pt-BR"

# Path to a Netscape-format cookie file for yt-dlp YouTube authentication.
# Optional - leave empty to download without authentication.
# See docs/cookie-extraction.md for instructions on exporting cookies from your browser.
YT_DLP_COOKIE_FILE=""

# Autopulse notification (optional). Uncomment and set URL to enable Plex scan after trailer download.
# AUTOPULSE_URL="http://ip:3030"
# AUTOPULSE_TRIGGER="manual"
# AUTOPULSE_AUTH_USER="username"
# AUTOPULSE_AUTH_PASS="password"

# yt-dlp format selector. Default gets best quality then recodes to MP4 for compatibility.
# YT_DLP_FORMAT="bv*+ba/b"

# Target container for --recode-video. MP4 ensures H.264+AAC — Direct Play on all devices.
# YT_DLP_RECODE="mp4"

# Dry-run mode. When true, skips actual yt-dlp download, shows what would happen.
DRY_RUN="false"

# Debug mode. When true, prints detailed diagnostic messages.
DEBUG="false"

# --- Auto Quality Switch settings (optional) ---
# Quality profile names for the auto quality switch script.
# SOURCE_PROFILE_NAME="Remux-2160p"
# TARGET_PROFILE_NAME="WebDL-2160p"

# Percentile threshold for web->physical gap (0.0-1.0).
# P95 = wait until 95% of physical releases have appeared.
# P_VALUE="0.95"

# Minimum sample of movies with both dates needed to compute threshold.
# Below this, FALLBACK_THRESHOLD is used.
# MIN_SAMPLE="30"

# Hardcoded fallback threshold (days) when sample is too small.
# FALLBACK_THRESHOLD="365"

# Clamping bounds for computed threshold.
# MIN_THRESHOLD="90"
# MAX_THRESHOLD="730"

# Max movies to switch per run. 0 = unlimited.
# MAX_SWITCH_PER_RUN="0"

# Trigger Radarr search after profile switch.
# TRIGGER_SEARCH="true"

# Radarr tag to mark movies switched by the forward script.
# Used by the reverse script to identify candidates for switching back.
# AUTO_SWITCH_TAG="auto-switched"
